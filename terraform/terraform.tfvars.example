# terraform.tfvars.example
# Copy to terraform.tfvars and adjust values.
# terraform.tfvars is typically gitignored to avoid committing secrets.

aws_region         = "us-east-1"
environment        = "dev"
instance_type      = "t3.micro"
asg_min_size       = 2
asg_max_size       = 4
asg_desired_capacity = 2
app_port           = 3000

# Restrict SSH to your IP in production (e.g., "203.0.113.42/32")
ssh_allowed_cidr   = "0.0.0.0/0"
